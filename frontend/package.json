{
  "name": "official-doc-ai-assistant",
  "private": true,
  "version": "1.4.8",
  "description": "AI 公文智能优化助手 — 公文格式检测与优化桌面工具",
  "author": "Jose AI <admin@linhut.cn>",
  "homepage": "https://github.com/linhut/document-ai-assistant",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"tsc -p tsconfig.electron.json && electron .\"",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:build": "cd .. && python build_backend.py && cd frontend && vite build && tsc -p tsconfig.electron.json && electron-builder --win --x64",
    "electron:build:preview": "cd .. && python build_backend.py && cd frontend && vite build && tsc -p tsconfig.electron.json && electron-builder --win --x64 --publish=never",
    "electron:build:linux": "cd .. && python3 build_backend.py && cd frontend && vite build && tsc -p tsconfig.electron.json && electron-builder --linux --x64 --publish=never",
    "electron:build:linux:arm64": "cd .. && python3 build_backend.py && cd frontend && vite build && tsc -p tsconfig.electron.json && electron-builder --linux --arm64 --publish=never"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "axios": "^1.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.officialdoc.ai-assistant",
    "productName": "AI公文智能优化助手",
    "copyright": "Copyright © 2026 Jose AI - www.linhut.cn",
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "electron/dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "executableName": "AI-Document-Assistant",
      "artifactName": "doc-optimizer-v${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI公文助手",
      "unicode": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "executableName": "ai-document-assistant",
      "artifactName": "doc-optimizer-v${version}-${arch}.${ext}",
      "category": "Office"
    },
    "deb": {
      "depends": ["libreoffice-common"]
    },
    "mac": {
      "target": ["dmg"],
      "artifactName": "doc-optimizer-v${version}-${arch}.${ext}",
      "category": "public.app-category.productivity"
    },
    "extraResources": [
      {
        "from": "dist-resources/backend/backend_server",
        "to": "backend_server"
      },
      {
        "from": "dist-resources/backend/rules",
        "to": "rules"
      },
      {
        "from": "dist-resources/backend/templates",
        "to": "templates"
      },
      {
        "from": "dist-resources/backend/TTF",
        "to": "TTF"
      },
      {
        "from": "dist-resources/backend/data",
        "to": "data"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ]
  }
}