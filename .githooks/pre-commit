#!/bin/bash
# ============================================================
# Pre-commit hook: 禁止提交非必要文件和中文路径
# Prevents committing unnecessary files and Chinese-named paths
# ============================================================

set -e

echo "🔍 Pre-commit hook: Checking for forbidden files..."

# Check 1: Chinese characters in file/directory names (outside allowed paths)
CHINESE_FILES=$(git diff --cached --name-only | grep -E '[\x{4e00}-\x{9fff}\x{3400}-\x{4dbf}\x{ff00}-\x{ffef}]' || true)
if [ -n "$CHINESE_FILES" ]; then
  echo "❌ ERROR: Files with Chinese characters detected in commit:"
  echo "$CHINESE_FILES"
  echo ""
  echo "  请重命名包含中文的路径为英文名称，例如："
  echo "    公文模板/  →  dotx_templates/"
  echo "    启动应用.bat  →  startup.bat"
  echo ""
  exit 1
fi

# Check 2: Office lock/temp files
LOCK_FILES=$(git diff --cached --name-only | grep -E '^~\$' || true)
if [ -n "$LOCK_FILES" ]; then
  echo "❌ ERROR: Office temporary lock files detected:"
  echo "$LOCK_FILES"
  echo "  Close the Office document and delete the temp file, then try again."
  exit 1
fi

# Check 3: Forbidden directories/files from .gitignore category
FORBIDDEN_PATTERNS=(
  "docs/archive/"
  "docs/reports/"
  "docs/OPTIMIZATION_REPORT.md"
  "docs/refactor-feasibility-report.md"
)
for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
  MATCH=$(git diff --cached --name-only | grep -E "$pattern" || true)
  if [ -n "$MATCH" ]; then
    echo "❌ ERROR: Forbidden file/directory detected: $pattern"
    echo "$MATCH"
    echo "  These files are old reports/archives and should not be committed."
    exit 1
  fi
done

# Check 4: Large binary files (>500KB)
LARGE_FILES=$(git diff --cached --name-only | while read -r file; do
  if [ -f "$file" ]; then
    size=$(wc -c < "$file" 2>/dev/null || echo 0)
    if [ "$size" -gt 512000 ] 2>/dev/null; then
      # Allow known large directories like TTF (fonts are needed)
      case "$file" in
        TTF/*) ;;
        dotx_templates/*) ;;
        *) echo "$file ($(numfmt --to=iec $size 2>/dev/null || echo "${size}B"))" ;;
      esac
    fi
  fi
done)

if [ -n "$LARGE_FILES" ]; then
  echo "⚠️  WARNING: Large files detected in commit:"
  echo "$LARGE_FILES"
  echo "  If these are intentional, use --no-verify to bypass."
  echo "  Otherwise, move them to appropriate storage."
  echo ""
fi

# Check 5: Binary file extensions that shouldn't be committed
BINARY_PATTERNS=(
  "\.exe$"
  "\.msi$"
  "\.dmg$"
  "\.AppImage$"
  "\.deb$"
  "\.rpm$"
  "\.zip$"
)
for pattern in "${BINARY_PATTERNS[@]}"; do
  MATCH=$(git diff --cached --name-only | grep -E "$pattern" || true)
  if [ -n "$MATCH" ]; then
    echo "❌ ERROR: Build output files should not be committed:"
    echo "$MATCH"
    echo "  These are generated by CI/CD pipelines."
    exit 1
  fi
done

echo "✅ Pre-commit check passed!"
exit 0
